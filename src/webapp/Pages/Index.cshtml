@page
@model IndexModel
@{
    ViewData["Title"] = "ToDo List";
}

<section class="todo-shell">
    <div class="todo-header">
        <h1 class="display-6">Mission Control ToDos</h1>
        <p class="text-muted mb-0">Track tasks by category, due date, and priority.</p>
    </div>

    <form method="post" asp-page-handler="Add" class="row g-3 todo-form">
        <div class="col-md-5">
            <label asp-for="Input.Title" class="form-label"></label>
            <input asp-for="Input.Title" class="form-control" placeholder="Add a task..." />
            <span asp-validation-for="Input.Title" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Input.Category" class="form-label"></label>
            <select asp-for="Input.Category" class="form-select">
                @foreach (var category in Model.Categories)
                {
                    <option value="@category">@category</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="Input.Priority" class="form-label"></label>
            <select asp-for="Input.Priority" class="form-select">
                @foreach (var priority in Model.Priorities)
                {
                    <option value="@priority">@priority</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <label asp-for="Input.DueDate" class="form-label"></label>
            <input asp-for="Input.DueDate" class="form-control" type="date" />
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-primary">Add ToDo</button>
        </div>
    </form>

    <div class="todo-list mt-4">
        @if (Model.TodoItems.Count == 0)
        {
            <p class="text-muted mb-0">No tasks yet — add your first one above.</p>
        }
        else
        {
            @foreach (var item in Model.TodoItems)
            {
                <article class="todo-item @(item.IsCompleted ? "todo-item-complete" : string.Empty)">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <h2 class="h5 mb-1">@item.Title</h2>
                            <p class="mb-0 text-muted">
                                <span class="badge category-badge">@item.Category</span>
                                <span class="badge bg-dark-subtle text-dark-emphasis">@item.Priority</span>
                                @if (item.DueDate is not null)
                                {
                                    <span class="badge bg-info-subtle text-info-emphasis">Due @item.DueDate.Value.ToString("yyyy-MM-dd")</span>
                                }
                            </p>
                        </div>
                        <form method="post" asp-page-handler="Toggle" class="mb-0">
                            <input type="hidden" name="id" value="@item.Id" />
                            <button class="btn btn-outline-secondary btn-sm" type="submit">
                                @(item.IsCompleted ? "Mark Active" : "Mark Complete")
                            </button>
                        </form>
                    </div>
                </article>
            }
        }
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
